# ─── MQTT (HiveMQ Cloud) ───────────────────────────────────────────────────────
MQTT_BROKER_URL=your-cluster.s1.eu.hivemq.cloud
MQTT_USERNAME=hardware_push
MQTT_PASSWORD=your_password_here
MQTT_PORT=8883

# ─── Firebase Admin SDK ────────────────────────────────────────────────────────
FIREBASE_ADMIN_PROJECT_ID=smart-flush-system
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@smart-flush-system.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── Device ────────────────────────────────────────────────────────────────────
MQTT_DEVICE_ID=toilet-01
